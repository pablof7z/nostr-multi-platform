//! Minimal headless shell stub for `{{display}}`.
//!
//! A real platform shell (SwiftUI / Compose / iced / wasm) drives the
//! generated `nmp-app-{{name}}` FFI surface. This stub stays dependency-free
//! — it just assembles the app's module registry and prints it, proving the
//! `{{pkg}}` skeleton wires together. Run it with:
//!
//! ```sh
//! cargo run --example shell -p {{pkg}}
//! ```

use {{crate_ident}}::module_namespaces;

fn main() {
    let namespaces = module_namespaces();
    println!(
        "{{display}} assembled {} module(s):",
        namespaces.len()
    );
    for namespace in namespaces {
        println!("  {}", namespace);
    }
}
