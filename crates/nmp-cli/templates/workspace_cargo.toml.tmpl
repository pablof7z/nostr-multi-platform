# Scaffolded by `nmp init {{name}}`.
#
# The generated FFI crate (apps/{{name}}/nmp-app-{{name}}, produced by
# `nmp gen modules`) is intentionally NOT a member here until you are ready
# to link a native shell. See README.md for the release vs. local NMP
# dependency modes.
[workspace]
members = ["crates/{{pkg}}"]
resolver = "2"

[workspace.package]
edition = "2021"
license = "MIT"
version = "0.1.0"
